{
  "extends": "@vue/tsconfig/tsconfig.web.json",
  "include": [
    "env.d.ts",
    "src/**/*",
    "src/**/*.vue"
  ],
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@": [
        "./src"
      ],
      "@/*": [
        "./src/*"
      ],
      "echarts-gl": [
        "node_modules/echarts-gl/dist/echarts-gl.min.js"
      ]
    }
  },
  "type": [
    "node"
  ]
}